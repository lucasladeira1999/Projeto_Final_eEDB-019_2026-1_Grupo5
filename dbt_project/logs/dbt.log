    as
  
  (
    with stations as (
    select
        cast(start_station_id as text) as station_id,
        start_station_name as station_name
    from "bike_elt"."silver_silver"."stg_trips"

    union all

    select
        cast(end_station_id as text) as station_id,
        end_station_name as station_name
    from "bike_elt"."silver_silver"."stg_trips"
)
select distinct
    md5(cast(coalesce(cast(station_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(station_name as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as station_key,
    station_id,
    station_name
from stations
where station_id is not null
  and station_name is not null;
  );
  
